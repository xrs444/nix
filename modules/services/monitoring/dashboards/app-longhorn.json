{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Longhorn distributed storage: volume health, replica count, disk per node, backup status, IOPS",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "up{job=\"longhorn\"}", "legendFormat": "Longhorn" }
      ],
      "title": "Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "count(longhorn_volume_robustness == 0)", "legendFormat": "Healthy" }
      ],
      "title": "Healthy Volumes",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "count(longhorn_volume_robustness > 0) or vector(0)", "legendFormat": "Degraded" }
      ],
      "title": "Degraded/Faulted Volumes",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["max"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "max((longhorn_disk_usage_bytes / longhorn_disk_capacity_bytes) * 100)", "legendFormat": "Max disk %" }
      ],
      "title": "Max Disk Usage",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "sum(longhorn_volume_actual_size_bytes)", "legendFormat": "Used" }
      ],
      "title": "Total Storage Used",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Volumes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] },
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } },
          "mappings": [{ "options": { "0": { "text": "Healthy" }, "1": { "text": "Degraded" }, "2": { "text": "Faulted" } }, "type": "value" }]
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "volume" }, "properties": [{ "id": "custom.width", "value": 300 }] },
          { "matcher": { "id": "byName", "options": "node" }, "properties": [{ "id": "custom.width", "value": 200 }] }
        ]
      },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 6 },
      "id": 11,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Robustness" }] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "longhorn_volume_robustness", "legendFormat": "{{volume}}", "instant": true }
      ],
      "title": "Volume Robustness",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] },
          "unit": "percent",
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "volume" }, "properties": [{ "id": "custom.width", "value": 300 }] }
        ]
      },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 6 },
      "id": 12,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Usage %" }] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "(longhorn_volume_actual_size_bytes / longhorn_volume_capacity_bytes) * 100", "legendFormat": "{{volume}}", "instant": true }
      ],
      "title": "Volume Fill Level",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 20,
      "title": "Disk Usage per Node",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent",
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "node" }, "properties": [{ "id": "custom.width", "value": 250 }] },
          { "matcher": { "id": "byName", "options": "disk" }, "properties": [{ "id": "custom.width", "value": 200 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 21,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Usage %" }] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "(longhorn_disk_usage_bytes / longhorn_disk_capacity_bytes) * 100", "legendFormat": "{{node}} / {{disk}}", "instant": true }
      ],
      "title": "Disk Usage by Node",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 22,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "sum by (node) (longhorn_disk_usage_bytes)", "legendFormat": "{{node}}" }
      ],
      "title": "Storage Used per Node",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 30,
      "title": "IOPS & Throughput",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "iops"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 31,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "topk(10, rate(longhorn_volume_read_iops[5m]))", "legendFormat": "{{volume}} R" },
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "topk(10, rate(longhorn_volume_write_iops[5m]))", "legendFormat": "{{volume}} W" }
      ],
      "title": "Volume IOPS (top 10)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 32,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "topk(10, rate(longhorn_volume_read_throughput[5m]))", "legendFormat": "{{volume}} R" },
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "topk(10, rate(longhorn_volume_write_throughput[5m]))", "legendFormat": "{{volume}} W" }
      ],
      "title": "Volume Throughput (top 10)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 40,
      "title": "Backup Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "custom": { "align": "auto" }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 37 },
      "id": 41,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "longhorn_backup_state", "legendFormat": "{{volume}} / {{backup}}", "instant": true }
      ],
      "title": "Backup State",
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["longhorn", "storage", "infrastructure"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Longhorn",
  "uid": "app-longhorn",
  "version": 1
}
