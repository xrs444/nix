{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Network overview: BGP session status, Tailscale exit node, blackbox probe results. SNMP deferred.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Endpoint Probe Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }],
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Target" }, "properties": [{ "id": "custom.width", "value": 350 }] },
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "custom.width", "value": 100 }] }
        ]
      },
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": false, "displayName": "Target" }] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "probe_success{job=\"blackbox-ssl\"}", "legendFormat": "{{instance}}", "instant": true }
      ],
      "title": "HTTPS / SSL Endpoint Status",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "valueLabel": "Status" } },
        { "id": "organize", "options": { "renameByName": { "instance": "Target", "Value": "Status" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 604800 }, { "color": "green", "value": 2592000 }] },
          "unit": "dtdurations",
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Target" }, "properties": [{ "id": "custom.width", "value": 350 }] }
        ]
      },
      "gridPos": { "h": 12, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": false, "displayName": "Expires In" }] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "probe_ssl_earliest_cert_expiry{job=\"blackbox-ssl\"} - time()", "legendFormat": "{{instance}}", "instant": true }
      ],
      "title": "SSL Certificate Expiry",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "valueLabel": "Expires In" } },
        { "id": "organize", "options": { "renameByName": { "instance": "Target", "Value": "Expires In" } } }
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 13 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "asc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "probe_duration_seconds{job=\"blackbox-ssl\"}", "legendFormat": "{{instance}}" }
      ],
      "title": "Probe Duration",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 10,
      "title": "BGP Sessions (Bird — xts1 / xts2)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }],
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "instance" }, "properties": [{ "id": "custom.width", "value": 200 }] },
          { "matcher": { "id": "byName", "options": "name" }, "properties": [{ "id": "custom.width", "value": 200 }] },
          { "matcher": { "id": "byName", "options": "proto" }, "properties": [{ "id": "custom.width", "value": 80 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "id": 11,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": false, "displayName": "instance" }] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "bird_protocol_up{job=\"bird\"}", "legendFormat": "{{instance}} {{name}} ({{proto}})", "instant": true }
      ],
      "title": "BGP Protocol Sessions",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "rate(bird_protocol_prefix_count{job=\"bird\", direction=\"import\"}[5m])", "legendFormat": "{{instance}} {{name}} import" },
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "rate(bird_protocol_prefix_count{job=\"bird\", direction=\"export\"}[5m])", "legendFormat": "{{instance}} {{name}} export" }
      ],
      "title": "BGP Prefix Counts",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "id": 13,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "rate(bird_protocol_route_changes_total{job=\"bird\"}[5m])", "legendFormat": "{{instance}} {{name}} {{action}}" }
      ],
      "title": "BGP Route Changes",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 20,
      "title": "Tailscale Exit Node",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 39 },
      "id": 21,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "up{job=\"tailscale\", instance=~\"xts1.*\"}", "legendFormat": "xts1 Tailscale" }
      ],
      "title": "xts1 Tailscale",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [{ "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 39 },
      "id": 22,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "up{job=\"tailscale\", instance=~\"xts2.*\"}", "legendFormat": "xts2 Tailscale" }
      ],
      "title": "xts2 Tailscale",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 23,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "irate(node_network_receive_bytes_total{job=\"node\", instance=~\"xts1.lan:9100|xts2.lan:9100\", device=\"tailscale0\"}[5m])", "legendFormat": "{{instance}} RX" },
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "irate(node_network_transmit_bytes_total{job=\"node\", instance=~\"xts1.lan:9100|xts2.lan:9100\", device=\"tailscale0\"}[5m])", "legendFormat": "{{instance}} TX" }
      ],
      "title": "Tailscale Interface Throughput",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 24,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "node_network_receive_packets_total{job=\"node\", instance=~\"xts1.lan:9100|xts2.lan:9100\", device=\"tailscale0\"}", "legendFormat": "{{instance}} RX packets" },
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "node_network_transmit_packets_total{job=\"node\", instance=~\"xts1.lan:9100|xts2.lan:9100\", device=\"tailscale0\"}", "legendFormat": "{{instance}} TX packets" }
      ],
      "title": "Tailscale Packet Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 },
      "id": 30,
      "title": "SNMP Network Devices (Placeholder — SNMP Deferred)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 52 },
      "id": 31,
      "options": { "content": "## SNMP Monitoring Not Yet Configured\n\nSNMP scraping for switches and APs is deferred. To enable:\n\n1. Generate SNMP exporter config: see [snmp_exporter generator](https://github.com/prometheus/snmp_exporter/tree/main/generator)\n2. Re-enable `services.prometheus.exporters.snmp` in `exporters.nix`\n3. Add scrape jobs to `prometheus.nix` targeting Firewalla and OUI switches\n\nCurrent SNMP exporter port: 9116 (pre-allocated in firewall rules).", "mode": "markdown" },
      "title": "",
      "type": "text"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "tags": ["network", "bgp", "tailscale", "blackbox"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
