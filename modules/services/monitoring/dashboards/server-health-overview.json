{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "CPU, memory, disk, and network for all NixOS servers at a glance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 200,
      "title": "CPU Usage %",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineInterpolation": "linear", "lineWidth": 2, "pointSize": 5, "scaleDistribution": { "type": "linear" }, "showPoints": "never", "spanNulls": true, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } },
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 201,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\",instance=~\"172.20.1.10:9100|172.20.1.20:9100|172.20.1.30:9100\"}[5m])) * 100)", "legendFormat": "{{instance}}" },
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\",instance=~\"xts1.lan:9100|xts2.lan:9100|xcomm1.lan:9100|xpbx1.lan:9100|cmrpi1.lan:9100\"}[5m])) * 100)", "legendFormat": "{{instance}}" }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 210,
      "title": "Memory Usage %",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": true, "stacking": { "group": "A", "mode": "none" } },
          "max": 100,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 90 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 10 },
      "id": 211,
      "options": { "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "{{instance}}" }
      ],
      "title": "Memory Usage",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 220,
      "title": "Disk Usage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] },
          "unit": "percent",
          "custom": { "align": "auto", "cellOptions": { "type": "color-background" } }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
      "id": 221,
      "options": { "footer": { "fields": "", "reducer": ["sum"], "show": false }, "showHeader": true, "sortBy": [{ "desc": true, "displayName": "Usage %" }] },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "100 - ((node_filesystem_avail_bytes{fstype!~\"tmpfs|fuse.lxcfs|squashfs|vfat|devtmpfs\",mountpoint!~\"/boot.*\"} / node_filesystem_size_bytes) * 100)", "legendFormat": "{{instance}} {{mountpoint}}", "instant": true }
      ],
      "title": "Disk Usage by Mount",
      "transformations": [{ "id": "sortBy", "options": { "fields": [{ "desc": true, "displayName": "Value" }] } }],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
      "id": 230,
      "title": "Network I/O",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "id": 231,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "irate(node_network_receive_bytes_total{device=~\"bond0|eth0|enp.*\",instance=~\"172.20.1.10:9100|172.20.1.20:9100|172.20.1.30:9100\"}[5m])", "legendFormat": "{{instance}} RX" }
      ],
      "title": "Network Receive (Servers)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "id": 232,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "irate(node_network_transmit_bytes_total{device=~\"bond0|eth0|enp.*\",instance=~\"172.20.1.10:9100|172.20.1.20:9100|172.20.1.30:9100\"}[5m])", "legendFormat": "{{instance}} TX" }
      ],
      "title": "Network Transmit (Servers)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "id": 240,
      "title": "System Uptime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 86400 }, { "color": "green", "value": 604800 }] },
          "unit": "dtdurations",
          "custom": { "align": "auto" }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 39 },
      "id": 241,
      "options": { "showHeader": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "time() - node_boot_time_seconds", "legendFormat": "{{instance}}", "instant": true }
      ],
      "title": "System Uptime",
      "type": "table"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["system", "servers"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Server Health Overview",
  "uid": "server-health-overview",
  "version": 1
}
