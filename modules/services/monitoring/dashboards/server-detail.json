        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 40 },
      "id": 342,
      "options": { "showHeader": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "smartctl_device_temperature{instance=\"$instance\"}", "legendFormat": "{{device}}", "instant": true }
