      "options": { "showHeader": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "000000001" }, "expr": "smartctl_device_smart_healthy{instance=\"$instance\"}", "legendFormat": "{{device}}", "instant": true }
      ],
      "title": "SMART Health",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "000000001" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
